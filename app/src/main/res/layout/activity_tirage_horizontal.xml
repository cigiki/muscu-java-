<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tirage horizontal"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:textColor="#333333" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Le tirage horizontal est un exercice de musculation qui cible principalement les muscles du dos, notamment le grand dorsal, le grand rond et les rhomboïdes. Réalisé sur une machine à poulie avec une prise en pronation ou en supination, il permet de développer l'épaisseur du dos et la force de traction horizontale. C'est un excellent complément aux tractions verticales, offrant une sollicitation différente des muscles dorsaux. L'exercice peut être réalisé avec différentes poignées (large, neutre, serrée) pour varier les angles de travail et l'activation musculaire."
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:textColor="#666666"
            android:layout_marginBottom="20dp" />

        <ImageView
            android:id="@+id/gifTirageHorizontal"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:contentDescription="Animation tirage horizontal poulie"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp" />

    </LinearLayout>

</ScrollView>