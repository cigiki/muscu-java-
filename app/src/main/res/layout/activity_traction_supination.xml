<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Traction supination (Chin up)"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            android:textColor="#333333" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="La traction en supination, également appelée chin up, est une variante des tractions où les paumes des mains sont tournées vers soi. Cette prise sollicite davantage les biceps que la version classique en pronation, tout en travaillant intensément le grand dorsal. C'est souvent un exercice plus accessible pour les débutants car la participation des biceps facilite le mouvement. Le chin up développe la largeur du dos, la force des bras et améliore la posture. Il peut être réalisé avec différentes largeurs de prise pour varier les zones de travail."
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:textColor="#666666"
            android:layout_marginBottom="20dp" />

        <ImageView
            android:id="@+id/gifTractionSupination"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:contentDescription="Animation traction supination chin up"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp" />

    </LinearLayout>

</ScrollView>