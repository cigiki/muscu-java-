<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="40dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/btnExercice"
        android:text="Exercices de musculation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnPlanning"
        android:text="Planning"
        android:layout_marginTop="30dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <ImageView
        android:id="@+id/gifExercice"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/tractions_aux_anneaux"
        android:contentDescription="Animation traction aux anneaux"
        android:layout_marginBottom="30dp"/>

</LinearLayout>