        <Button android:text="Écarté poulie basse"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Écarté poulie haute"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Chest press machine"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Pec deck machine"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Pullover haltère"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
