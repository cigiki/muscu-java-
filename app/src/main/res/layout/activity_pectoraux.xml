            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Développé incliné barre"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Développé incliné haltères"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Développé décliné barre"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Développé décliné haltères"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Pompes classiques"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Pompes inclinées"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Pompes déclinées"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Pompes serrées"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content"/>

        <Button android:text="Dips pectoraux"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
